# Digital Health Record Management System - Configuration File

# 1. Flask Core Settings
FLASK_DEBUG=True
SECRET_KEY=kerala-health-key-12345!@#

# 2. Database Connection Options
# For SQLite fallback, set USE_SQLITE=True. For MySQL, set USE_SQLITE=False and fill credentials below.
USE_SQLITE=True
DB_HOST=localhost
DB_PORT=3306
DB_NAME=digital_health_system
DB_USER=root
DB_PASSWORD=password

# Or supply full Database URL directly:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/digital_health_system

# 3. JWT Token Settings
JWT_SECRET_KEY=jwt-health-secret-67890!@#

# 4. Frontend configuration variables
VITE_API_URL=http://localhost:5000/api
